#!/usr/bin/with-contenv bash
#
# Auto-generate any secrets that weren't provided so first-boot "just
# works" for noob installs. Secrets are written to /srv/config/.secrets
# so they persist across container restarts (the file lives on the
# named volume bound to ${SETVAULT_CONFIG_PATH}).
#
# If the user provided their own values in .env they take precedence.

set -e

CONFIG_DIR="${SETVAULT_CONFIG_PATH:-/srv/config}"
SECRETS_FILE="${CONFIG_DIR}/.secrets"
mkdir -p "${CONFIG_DIR}"

# Load any previously persisted secrets first.
if [ -f "${SECRETS_FILE}" ]; then
  # shellcheck disable=SC1090
  source "${SECRETS_FILE}"
fi

# Synthesize DATABASE_URL from POSTGRES_* if the user didn't pass one.
# Power users with an external postgres pass DATABASE_URL directly.
if [ -z "${DATABASE_URL}" ]; then
  if [ -z "${POSTGRES_PASSWORD}" ]; then
    if [ "${SETVAULT_PG_EMBEDDED}" = "1" ]; then
      # Bundled postgres + no password given: generate a strong one and persist
      # it (init-db.sh ALTER USERs the embedded role to match). Loopback-only,
      # but no reason to ship a weak default.
      POSTGRES_PASSWORD="$(python -c 'import secrets;print(secrets.token_urlsafe(24))')"
      echo "POSTGRES_PASSWORD=${POSTGRES_PASSWORD}" >> "${SECRETS_FILE}"
      echo "[setvault] generated embedded POSTGRES_PASSWORD (persisted to ${SECRETS_FILE})" >&2
    else
      # External postgres with neither DATABASE_URL nor POSTGRES_PASSWORD — leave
      # DATABASE_URL unset so 02-validate fails fast with a clear message.
      echo "[setvault] external mode: set DATABASE_URL or POSTGRES_PASSWORD" >&2
    fi
  fi
  if [ -n "${POSTGRES_PASSWORD}" ]; then
    DATABASE_URL="postgresql+asyncpg://${POSTGRES_USER:-setvault}:${POSTGRES_PASSWORD}@${POSTGRES_HOST:-postgres}:${POSTGRES_PORT:-5432}/${POSTGRES_DB:-setvault}"
  fi
fi

# Export so s6 longruns inherit via with-contenv.
export DATABASE_URL POSTGRES_PASSWORD
mkdir -p /run/s6/container_environment
printf '%s' "${DATABASE_URL}" > /run/s6/container_environment/DATABASE_URL
printf '%s' "${POSTGRES_PASSWORD}" > /run/s6/container_environment/POSTGRES_PASSWORD

# Default data directories — create on first boot so PUID/PGID bind-mounts
# don't fail with "directory not found".
for d in \
  "${SETVAULT_MEDIA_PATH:-/srv/media}" \
  "${SETVAULT_CACHE_PATH:-/srv/cache}" \
  "${SETVAULT_CONFIG_PATH:-/srv/config}" \
  "${SETVAULT_WATCH_FOLDERS_PATH:-/srv/watch}"; do
  mkdir -p "${d}"
  chown -R "${PUID:-1000}:${PGID:-1000}" "${d}" 2>/dev/null || true
done

# srv tree must be writable by app uid for the venv + caches.
chown -R "${PUID:-1000}:${PGID:-1000}" /srv/.venv 2>/dev/null || true
