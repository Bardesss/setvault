#!/usr/bin/with-contenv bash
#
# Run alembic migrations once before any longrun starts. Postgres may
# still be coming up if the user's compose doesn't have a healthcheck
# dependency, so retry a few times with backoff before giving up.

set -e

cd /srv

attempts=0
max_attempts=30
until s6-setuidgid "${PUID:-1000}:${PGID:-1000}" \
        /srv/.venv/bin/alembic upgrade head 2>&1; do
  attempts=$((attempts + 1))
  if [ "${attempts}" -ge "${max_attempts}" ]; then
    echo "[setvault] alembic upgrade failed after ${max_attempts} attempts; bailing" >&2
    exit 1
  fi
  echo "[setvault] alembic not ready (attempt ${attempts}/${max_attempts}); retrying in 2s" >&2
  sleep 2
done

echo "[setvault] migrations up-to-date" >&2
