#!/usr/bin/with-contenv bash
#
# Required-env check. Fails fast with a clear human message if the user
# forgot one of the three things every install needs, or set a weak SECRET_KEY.

set -e

missing=()
# SECRET_KEY is always set by 01-defaults (generated if absent), so it is no
# longer listed here — but the strength gate below still applies.
# BASE_URL is defaulted in bundled mode by 01-defaults; only external mode,
# where the operator chooses the public origin, still requires it.
[ -z "${BASE_URL}" ] && [ "${SETVAULT_PG_EMBEDDED}" != "1" ] && missing+=("BASE_URL")
[ -z "${DATABASE_URL}" ] && missing+=("DATABASE_URL (or POSTGRES_PASSWORD if using the bundled postgres)")

if [ ${#missing[@]} -gt 0 ]; then
  cat <<EOF >&2

============================================================
 SetVault: missing required environment variable(s):
EOF
  for v in "${missing[@]}"; do
    echo "   - ${v}" >&2
  done
  cat <<EOF >&2

 Edit your .env file (see .env.example) and restart.
 Generate strong secrets with:
     openssl rand -base64 48
============================================================
EOF
  exit 1
fi

# SECRET_KEY strength gate. It signs every session cookie and HMAC share URL,
# so a weak/known key means trivial session + stream-URL forgery.
if [ "${SECRET_KEY}" = "dev-only-do-not-use-in-prod" ]; then
  echo "[setvault] FATAL: SECRET_KEY is the public dev default. Set a real one: openssl rand -base64 48" >&2
  exit 1
fi
if [ "${#SECRET_KEY}" -lt 32 ]; then
  echo "[setvault] FATAL: SECRET_KEY is too short (<32 chars). Use: openssl rand -base64 48" >&2
  exit 1
fi
