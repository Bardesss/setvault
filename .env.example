# =============================================================================
# SetVault configuration — copy to `.env` and fill in.
# =============================================================================
# Required at minimum: SECRET_KEY, POSTGRES_PASSWORD, TUSD_HOOK_SECRET, BASE_URL
# Generate strong secrets: `openssl rand -base64 48`
# =============================================================================


# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------

# Signs session cookies + HMAC URLs. Rotating invalidates all sessions and
# in-flight signed enclosure URLs.
SECRET_KEY=replace-me-with-openssl-rand-base64-48

# Public URL the app is served from. Used in invite emails, RSS feed enclosure
# URLs, and embed-iframe `src` attributes. Set to your HTTPS reverse-proxy URL.
BASE_URL=http://localhost:8000

# Image tag for the GHCR-pull compose stack. Pin in production; set to
# `latest` if you want auto-bumps on `docker compose pull` (you re-run pull).
SETVAULT_VERSION=0.1.0


# -----------------------------------------------------------------------------
# Database — Postgres
# -----------------------------------------------------------------------------

POSTGRES_USER=setvault
POSTGRES_PASSWORD=replace-me-strong-postgres-password
POSTGRES_DB=setvault

# Async SQLAlchemy URL. Must match POSTGRES_USER/PASSWORD/DB above.
DATABASE_URL=postgresql+asyncpg://setvault:replace-me-strong-postgres-password@postgres:5432/setvault


# -----------------------------------------------------------------------------
# Queue + rate-limit store — Redis
# -----------------------------------------------------------------------------

REDIS_URL=redis://redis:6379/0


# -----------------------------------------------------------------------------
# Uploads — tusd sidecar
# -----------------------------------------------------------------------------

# Shared secret tusd uses to authenticate hook callbacks into the web service.
TUSD_HOOK_SECRET=replace-me-with-openssl-rand-base64-32


# -----------------------------------------------------------------------------
# Host paths (Docker bind-mounts)
# -----------------------------------------------------------------------------
# Defaults live under `./.data/` relative to the compose file. Override to
# point at fast disks for db/cache and slower disks for media if desired.

SETVAULT_DB_PATH=./.data/db
SETVAULT_REDIS_PATH=./.data/redis
SETVAULT_CACHE_PATH=./.data/cache
SETVAULT_CONFIG_PATH=./.data/config

# Media (your live-set files). Each MediaRoot you create in the admin UI must
# resolve to a path inside this mount.
SETVAULT_MEDIA_PATH=./.data/media

# Watch-folder mount. Disable the `watcher` service in compose.yml if unused.
SETVAULT_WATCH_FOLDERS_PATH=./.data/watch


# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------

# Host port the web service binds. Behind a reverse proxy, keep 8000 and
# forward HTTPS → http://web:8000.
SETVAULT_HTTP_PORT=8000


# -----------------------------------------------------------------------------
# Container UID/GID (for bind-mount permissions)
# -----------------------------------------------------------------------------

PUID=1000
PGID=1000


# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------

# Enable the dev-seed endpoint for first-admin bootstrap. Set to `1` for the
# very first container boot, hit POST /api/dev/seed-e2e, then UNSET and
# restart so the endpoint is no longer mounted.
# SETVAULT_DEV_SEED=

# Drop the `Secure` cookie flag on auth cookies. Only for local HTTP dev —
# leaving this on in production lets cookies be read over plain HTTP.
# SETVAULT_ALLOW_INSECURE_COOKIE=
