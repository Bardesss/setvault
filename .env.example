# =============================================================================
# SetVault - configuration
# =============================================================================
# Bundled (single-container) mode needs ZERO of these: SECRET_KEY and the
# internal POSTGRES_PASSWORD are generated on first boot, and BASE_URL defaults
# to http://localhost:1970. Set them only to override.
#
# Set BASE_URL to your public https:// URL when exposing SetVault to the
# internet (behind a TLS proxy) so the session cookie is marked Secure.
# Generate strong secrets: openssl rand -base64 48
# =============================================================================

# Recommended when internet-facing (otherwise auto-handled in bundled mode):
# SECRET_KEY=replace-me-with-openssl-rand-base64-48
# POSTGRES_PASSWORD=replace-me-strong-postgres-password
# BASE_URL=http://localhost:1970


# -----------------------------------------------------------------------------
# Optional - the lines below only need to be uncommented if you want to
# override the defaults shown.
# -----------------------------------------------------------------------------

# Image tag. The default floats on `latest` and pulls breaking changes
# unattended — ALWAYS pin an explicit version in production.
# SETVAULT_VERSION=0.6.0

# Host port the web service binds. Behind a reverse proxy, the default
# 1970 (year of the first live DJ set) is fine — override if you want.
# SETVAULT_HTTP_PORT=1970

# Bundled vs external datastores:
#   - Default (compose.aio.yml or bare `docker run`): Postgres + Redis + tusd
#     run INSIDE the container. Nothing else to deploy.
#   - Set DATABASE_URL and/or REDIS_URL to use an EXTERNAL server for that
#     datastore (compose.yml does this for you). Per-datastore: you may run
#     embedded Redis with external Postgres, or vice-versa.
# DATABASE_URL=postgresql+asyncpg://user:pass@external-host:5432/dbname
# REDIS_URL=redis://external-host:6379/0

# Host paths for bind mounts. Defaults drop everything under ./.data/
# SETVAULT_MEDIA_PATH=./.data/media
# SETVAULT_CACHE_PATH=./.data/cache
# SETVAULT_CONFIG_PATH=./.data/config
# SETVAULT_WATCH_FOLDERS_PATH=./.data/watch
# SETVAULT_DB_PATH=./.data/db
# SETVAULT_REDIS_PATH=./.data/redis

# Single data volume for bundled mode (holds db, redis, media, cache, config, watch)
# SETVAULT_DATA_PATH=./.data/setvault

# Container user/group for bind-mount permissions
# PUID=1000
# PGID=1000

# Dev/e2e only: enables the POST /api/dev/seed-e2e test endpoint. Real
# installs use the browser first-run wizard (or the create_admin CLI).
# Never set in production.
# SETVAULT_DEV_SEED=

# The session-cookie `Secure` flag follows your BASE_URL scheme automatically
# (https:// -> Secure on, http:// -> off), so VPN/LAN-only HTTP deployments
# work without any extra setting. This is a force-off override for unusual
# proxy setups only; never set it on an internet-exposed https:// instance.
# SETVAULT_ALLOW_INSECURE_COOKIE=
